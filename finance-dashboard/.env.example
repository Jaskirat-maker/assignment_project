# Spring datasource
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/finance_dashboard?useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=pass

# JWT settings
app.jwt.secret=your_super_secret_key_minimum_64_characters_long_for_HS512_algorithm_finance
app.jwt.expiration=86400000

# Hibernate
spring.jpa.show-sql=true
spring.jpa.hibernate.ddl-auto=update
